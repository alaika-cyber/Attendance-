APP_NAME=AI Attendance Framework
ENV=production
API_PREFIX=/api/v1
SECRET_KEY=replace-with-32-byte-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

DATABASE_URL=sqlite:////app/data/attendance.db

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER=
SMTP_USE_TLS=true
AUTO_MONTHLY_REPORTS_ENABLED=false
MONTHLY_REPORT_RUN_HOUR_UTC=8
LOW_ATTENDANCE_THRESHOLD_PERCENT=75
SUSPICIOUS_SPOOF_ATTEMPTS_24H=3

GEOFENCE_LAT=12.9716
GEOFENCE_LON=77.5946
GEOFENCE_RADIUS_METERS=300

MAX_SPOOF_SCORE=0.6
